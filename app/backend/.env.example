# =============================
# DB 接続（必須）
# =============================
DATABASE_URL=postgresql://rei_user:rei_password@db:5432/rei_db

# =============================
# Admin Token（必須）バッチ起動エンドポイントの認証トークン
# =============================
ADMIN_TOKEN=change_me_to_strong_random_token

# =============================
# reinfolib API（必須）不動産情報ライブラリAPIキー
# ref: https://www.reinfolib.mlit.go.jp/api/request
# =============================
RE_INFO_LIB_KEY=your_api_key_here

# =============================
# CORS（省略時は localhost:3000 のみ）
# =============================
# CORS_ORIGINS=["http://localhost:3000"]

# =============================
# バッチ設定（省略時はデフォルト値を使用）
# =============================
# BATCH_ZOOM_LEVEL=12
# BATCH_REQUEST_TIMEOUT_SEC=30
# BATCH_MAX_RETRIES=3
# BATCH_RETRY_BACKOFF_BASE_SEC=2.0
# BATCH_CONCURRENT_REQUESTS=3
